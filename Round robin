#include <stdio.h>

int main() {
    int n, tq;
    printf("Enter number of processes: ");
    scanf("%d", &n);

    int bt[n], rt[n];
    
    printf("Enter burst times:\n");
    for(int i = 0; i < n; i++) {
        scanf("%d", &bt[i]);
        rt[i] = bt[i]; // remaining time
    }

    printf("Enter time quantum: ");
    scanf("%d", &tq);

    int time = 0;
    int done;

    printf("\nGantt Chart:\n");

    do {
        done = 1;
        for(int i = 0; i < n; i++) {
            if(rt[i] > 0) {
                done = 0;

                if(rt[i] > tq) {
                    printf("P%d (%d-%d) | ", i+1, time, time+tq);
                    time += tq;
                    rt[i] -= tq;
                } else {
                    printf("P%d (%d-%d) | ", i+1, time, time+rt[i]);
                    time += rt[i];
                    rt[i] = 0;
                }
            }
        }
    } while(!done);

    return 0;
}
