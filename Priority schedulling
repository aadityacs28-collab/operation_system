#include <stdio.h>

int main() {
    int n;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    int bt[n], pr[n], p[n];

    // Input
    for(int i = 0; i < n; i++) {
        printf("Enter Burst Time and Priority for P%d: ", i+1);
        scanf("%d %d", &bt[i], &pr[i]);
        p[i] = i + 1;
    }

    // Sort by priority (lower = higher priority)
    for(int i = 0; i < n-1; i++) {
        for(int j = i+1; j < n; j++) {
            if(pr[i] > pr[j]) {
                // swap priority
                int temp = pr[i];
                pr[i] = pr[j];
                pr[j] = temp;

                // swap burst time
                temp = bt[i];
                bt[i] = bt[j];
                bt[j] = temp;

                // swap process id
                temp = p[i];
                p[i] = p[j];
                p[j] = temp;
            }
        }
    }

    int time = 0;

    printf("\nGantt Chart:\n| ");

    for(int i = 0; i < n; i++) {
        printf("P%d | ", p[i]);
    }

    printf("\n0");

    for(int i = 0; i < n; i++) {
        time += bt[i];
        printf("   %d", time);
    }

    return 0;
}
